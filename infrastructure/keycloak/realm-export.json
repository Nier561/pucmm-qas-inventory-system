{
  "id": "inventario",
  "realm": "Inventario",
  "displayName": "Sistema de Gestión de Inventarios Empresarial",
  "enabled": true,
  "clients": [
    {
      "clientId": "inventory-client",
      "name": "Inventory Client Application",
      "description": "Cliente confidencial de la aplicación de inventario.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8080"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "roles": {
    "realm": [
      { "name": "product:view", "description": "Ver catálogo de productos." },
      { "name": "product:manage", "description": "Crear, editar y eliminar productos." },
      { "name": "stock:view", "description": "Ver niveles de inventario e historial." },
      { "name": "stock:manage", "description": "Registrar entradas, salidas y ajustes de stock." },
      { "name": "report:view", "description": "Acceder y exportar reportes y dashboard." },
      { "name": "user:manage", "description": "Gestionar usuarios, roles y permisos." },
      { "name": "audit:view", "description": "Consultar registros de auditoría." }
    ]
  },
  "users": [
    {
      "username": "admin-user",
      "enabled": true,
      "email": "admin@inventario.local",
      "firstName": "Administrador",
      "lastName": "Prueba",
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_TEST_USER_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "product:view",
        "product:manage",
        "stock:view",
        "stock:manage",
        "report:view",
        "user:manage",
        "audit:view"
      ]
    },
    {
      "username": "viewer-user",
      "enabled": true,
      "email": "viewer@inventario.local",
      "firstName": "Consulta",
      "lastName": "Prueba",
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_TEST_USER_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "product:view",
        "stock:view",
        "report:view"
      ]
    }
  ]
}